# Optional AI Factory model settings.
# AI_PROVIDER=gemini
# AI_MODEL=gemini-2.5-flash
# AI_REVIEWER_MODEL=gemini-2.5-flash
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# AI_API_KEY=replace_me

# RAG database. Defaults match infra/rag/compose.yaml.
RAG_DATABASE_URL=postgresql://aifactory_rag:aifactory_rag@localhost:5432/aifactory_rag

# Mounted Windows fileserver path. Replace with your local mount path.
RAG_FILESERVER_PATH=/Volumes/company-share/docs

# RAG model settings. Gemini is the default for both embedding and answer generation.
RAG_EMBEDDING_PROVIDER=gemini
RAG_EMBEDDING_MODEL=gemini-embedding-001
RAG_LLM_PROVIDER=gemini
RAG_LLM_MODEL=gemini-2.5-flash
RAG_API_KEY=replace_me

# Optional local provider URL when a RAG provider is set to "ollama".
# OLLAMA_BASE_URL=http://localhost:11434

# Required only when rag.auth.enabled is true and provider is "entra".
ENTRA_TENANT_ID=replace_me
ENTRA_AUDIENCE=api://replace_me
